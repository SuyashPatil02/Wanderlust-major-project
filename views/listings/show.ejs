<% layout('layouts/boilerplate') %>

<script>
    const mapToken = "<%= process.env.MAP_TOKEN  %>";
</script>

<div class="row mt-3">
    <div class="col-lg-8 offset-lg-2">
        <h3><%= listing.title %></h3>
        <p class="text-muted mb-3">
            <i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %>
            <% if(reviewCount > 0) { %>
                • ⭐ <%= averageRating.toFixed(1) %> (<%= reviewCount %> reviews)
            <% } %>
        </p>
    </div>

    <div class="card col-lg-8 offset-lg-2 show-card listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
        <div class="card-body p-3">
            <p class="card-text">Hosted by <b><%= listing.owner.username %></b></p>
            <p class="card-text"><%= listing.description %></p>
            <p class="card-text">Price: &#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>
        </div>
    </div>

    <div class="col-lg-8 offset-lg-2 mt-3 d-flex gap-2 flex-wrap">
        <% if(currentUser) { %>
            <% if(isFavorite) { %>
                <form method="POST" action="/listings/<%= listing._id %>/favorite?_method=DELETE">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-outline-danger">♥ Remove from wishlist</button>
                </form>
            <% } else { %>
                <form method="POST" action="/listings/<%= listing._id %>/favorite">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-danger">♥ Save to wishlist</button>
                </form>
            <% } %>
        <% } %>

        <% if(currentUser && listing.owner._id.equals(currentUser._id)) { %>
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button class="btn btn-outline-dark">Delete</button>
            </form>
        <% } %>
    </div>

    <div class="col-lg-8 offset-lg-2 mb-4 mt-3">
        <% if(currentUser) { %>
            <hr />
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="mb-3 mt-3">
                    <label for="Rating" class="form-label">Rating</label>
                    <fieldset class="starability-slot mb-3">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>

                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
                    <div class="invalid-feedback">Please add some comments for the review.</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
            <hr />
        <% } %>

        <% if(listing.reviews.length > 0) { %>
            <h4>All Reviews</h4>
            <div class="row">
                <% for(review of listing.reviews) { %>
                    <div class="card col-md-5 ms-2 mb-3">
                        <div class="card-body">
                            <h5 class="card-title">@<%= review.author.username %></h5>
                            <p class="starability-result card-text" data-rating="<%= review.rating %>">Rated: <%= review.rating %> stars</p>
                            <p class="card-text"><%= review.comment %></p>
                            <% if(currentUser && review.author._id.equals(currentUser._id)) { %>
                                <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button class="btn btn-sm btn-dark">Delete</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>

    <div class="col-lg-8 offset-lg-2 mb-3">
        <h3>Where you'll be</h3>
        <div id="map" style="height: 400px;"></div>
    </div>
</div>

<script src="/js/map.js"></script>

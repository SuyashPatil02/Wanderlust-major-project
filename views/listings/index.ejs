<% layout('/layouts/boilerplate') %>

<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
    <h2 class="mb-0">Discover Unique Stays</h2>
    <a href="/listings/new" class="btn btn-dark">+ Add Listing</a>
</div>

<form class="card p-3 mt-3 filter-card" action="/listings" method="GET">
    <div class="row g-2">
        <div class="col-md-4">
            <input class="form-control" name="q" placeholder="Search by title, location, country" value="<%= filters.q || '' %>" />
        </div>
        <div class="col-md-2">
            <input type="number" class="form-control" name="minPrice" placeholder="Min price" value="<%= filters.minPrice || '' %>" min="0" />
        </div>
        <div class="col-md-2">
            <input type="number" class="form-control" name="maxPrice" placeholder="Max price" value="<%= filters.maxPrice || '' %>" min="0" />
        </div>
        <div class="col-md-2">
            <input class="form-control" name="country" placeholder="Country" value="<%= filters.country || '' %>" />
        </div>
        <div class="col-md-2">
            <select name="sort" class="form-select">
                <option value="recent" <%= filters.sort === 'recent' ? 'selected' : '' %>>Newest</option>
                <option value="priceAsc" <%= filters.sort === 'priceAsc' ? 'selected' : '' %>>Price: Low to High</option>
                <option value="priceDesc" <%= filters.sort === 'priceDesc' ? 'selected' : '' %>>Price: High to Low</option>
            </select>
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-danger" type="submit">Apply Filters</button>
        <a href="/listings" class="btn btn-outline-secondary">Reset</a>
    </div>
</form>

<% if(featuredListings.length) { %>
    <section class="mt-4">
        <h4 class="mb-3">Featured Listings</h4>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-3">
            <% for (const listing of featuredListings) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card featured-card">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">
                        <div class="card-body">
                            <p class="card-text"><b><%= listing.title %></b><br />
                                <i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %><br />
                                &#8377;<%= listing.price.toLocaleString('en-IN') %> / night
                            </p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    </section>
<% } %>

<section class="mt-4">
    <h4 class="mb-3">All Listings (<%= allListings.length %>)</h4>
    <% if (allListings.length === 0) { %>
        <div class="alert alert-warning">No listings matched your filters.</div>
    <% } else { %>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-3">
            <% for(let listing of allListings) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">
                        <div class="card-body">
                            <p class="card-text">
                                <b><%= listing.title %></b><br>
                                <i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %><br>
                                &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                            </p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>
    <% } %>
</section>

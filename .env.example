NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/wanderlust
ATLASDB_URI=mongodb+srv://<username>:<password>@<cluster>/<dbName>?retryWrites=true&w=majority
SECRET=replace-with-a-strong-session-secret

CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=wanderlust_DEV

MAP_TOKEN=your-mapbox-public-token
